{
  "name": "press-wind",
  "version": "0.3.3",
  "description": "Wordpress theme base with Tailwind CSS and Vite JS",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env APP_ENV=development vite & npm run watch:editor",
    "build": "APP_ENV=production vite build && npm run build:editor && npm run build:admin",
    "dev:admin": "cross-env APP_ENV=development vite --config admin/vite.config.js",
    "build:admin": "APP_ENV=production vite build --config admin/vite.config.js",
    "watch:editor": "APP_ENV=development IS_EDITOR=true node_modules/.bin/postcss -w --verbose --no-map assets/css/styles.css -o style-editor.css",
    "build:editor": "NODE_ENV=production IS_EDITOR=true node_modules/.bin/postcss assets/css/styles.css -o style-editor.css",
    "favicon": "node js-helpers/faviconGenerator.mjs",
    "php:lint": "./vendor/bin/duster lint",
    "php:fix": "./vendor/bin/duster fix"
  },
  "author": "Faramaz Patrick<info@goodmotion.fr>",
  "license": "ISC",
  "trustedDependencies": [
    "sharp"
  ],
  "devDependencies": {
    "@_tw/themejson": "0.2.1",
    "@biomejs/biome": "^2.2.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-legacy": "7.2.1",
    "@vitejs/plugin-react": "5.0.1",
    "@wordpress/browserslist-config": "6.28.0",
    "@wordpress/components": "30.1.0",
    "@wordpress/compose": "7.28.0",
    "@wordpress/data": "10.28.0",
    "@wordpress/edit-post": "8.28.0",
    "@wordpress/element": "6.28.0",
    "@wordpress/eslint-plugin": "22.14.0",
    "@wordpress/i18n": "6.1.0",
    "@wordpress/icons": "10.28.0",
    "@wordpress/plugins": "7.28.0",
    "@wordpress/scripts": "30.21.0",
    "@wordpress/stylelint-config": "23.20.0",
    "autoprefixer": "^10.4.21",
    "babel-preset-env": "^1.7.0",
    "browserslist": "^4.25.3",
    "classnames": "^2.5.1",
    "cross-env": "^10.0.0",
    "favicons": "^7.2.0",
    "lightningcss": "^1.30.1",
    "lightningcss-cli": "^1.30.1",
    "postcss": "8.5.6",
    "postcss-cli": "11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^10.2.4",
    "postcss-url": "^10.1.3",
    "sharp": "^0.34.3",
    "tailwindcss": "3.4.7",
    "terser": "5.43.1",
    "vite": "7.1.3",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-live-reload": "3.0.5"
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "dependencies": {
    "flickity": "^3.0.0"
  }
}